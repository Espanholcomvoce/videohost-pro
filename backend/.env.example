# Base de datos PostgreSQL (Neon.tech - gratis)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Backblaze B2 (gratis hasta 10GB, sin tarjeta)
B2_KEY_ID=your_key_id
B2_APP_KEY=your_application_key
B2_BUCKET_NAME=videohost-pro
B2_REGION=us-west-004
B2_PUBLIC_URL=https://f004.backblazeb2.com/file/videohost-pro

# Admin dashboard
ADMIN_USER=admin
ADMIN_PASSWORD=senha_forte_aqui

# JWT (cualquier string largo y aleatorio)
JWT_SECRET=your_jwt_secret_here_min_32_chars

# FFmpeg (en Render.com ya está instalado)
FFMPEG_PATH=/usr/bin/ffmpeg
FFPROBE_PATH=/usr/bin/ffprobe

PORT=3000
NODE_ENV=production
